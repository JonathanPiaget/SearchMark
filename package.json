{
	"name": "searchmark",
	"description": "A browser extension for efficient bookmark management with search capabilities",
	"private": true,
	"version": "1.13.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"analyze": "wxt build --analyze --analyze-open",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "vue-tsc --noEmit",
		"postinstall": "wxt prepare",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "wxt build && playwright test",
		"test:e2e:ui": "wxt build && playwright test --ui",
		"screenshots": "wxt build && node screenshots/cli.mjs"
	},
	"dependencies": {
		"@wxt-dev/i18n": "^0.2.5",
		"fuzzysort": "^3.1.0",
		"vue": "^3.5.38"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@iconify-json/lucide": "^1.2.114",
		"@playwright/test": "^1.61.1",
		"@wxt-dev/module-vue": "^1.0.3",
		"playwright": "^1.61.1",
		"typescript": "6.0.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.1.0",
		"vitest": "^4.1.9",
		"vue-tsc": "^3.3.5",
		"wxt": "^0.20.27"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
