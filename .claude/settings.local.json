{
	"permissions": {
		"allow": [
			"Bash(pnpm run check)",
			"Bash(pnpm run lint)",
			"Bash(pnpm run build)",
			"mcp__context7__resolve-library-id",
			"Bash(npm run check:*)",
			"Bash(npm run build:*)",
			"mcp__context7__get-library-docs",
			"Bash(pnpm check:*)",
			"Bash(pnpm test:*)",
			"Bash(grep:*)"
		],
		"deny": []
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "osascript -e 'display dialog \"Waiting for your input...\" with title \"Claude Code\"'"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "osascript -e 'display dialog \"Stopping the process...\" with title \"Claude Code\"'"
					}
				]
			}
		]
	}
}
